<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Заголовок -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Редактирование автомобиля"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp" />

        <!-- Марка -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Марка:"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etBrand"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: BMW"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Модель -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Модель:"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etModel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: 5 Series"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Год выпуска -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Год выпуска:"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etYear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: 2020"
            android:inputType="number"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Объем двигателя -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Объем двигателя (л):"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etEngineVolume"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: 3.0"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Тип двигателя -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Тип двигателя:"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerEngineType"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Цена за час -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Цена за час ($):"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPriceHour"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: 20"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Цена за сутки -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Цена за сутки ($):"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPriceDay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: 150"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Цена за неделю -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Цена за неделю ($):"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPriceWeek"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: 700"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <!-- Имя файла картинки -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Имя файла картинки:"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etImageUrl"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Например: bmw"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="24dp"/>

        <!-- Кнопки -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="СОХРАНИТЬ ИЗМЕНЕНИЯ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#6200EE"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="УДАЛИТЬ АВТОМОБИЛЬ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#F44336"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="НАЗАД"
            android:textSize="16sp"
            android:backgroundTint="#666666"/>

    </LinearLayout>
</ScrollView>